from src.data_loader import load_telecom_data
from src.features import add_custom_features
from src.preprocessing import split_data, get_preprocessor
from src.models import train_baseline_models, run_grid_search
from src.utils import save_eda_plots, save_model_visuals, write_report
from sklearn.metrics import roc_auc_score, recall_score, precision_score, f1_score, accuracy_score

# Config
RANDOM_STATE = 42

# 1. Load & EDA
df = load_telecom_data(random_state=RANDOM_STATE)
save_eda_plots(df)

# 2. Features
df = add_custom_features(df)

# 3. Preprocess
X_train, X_test, y_train, y_test = split_data(df)
num_cols = ['tenure', 'MonthlyCharges', 'TotalCharges', 'SeniorCitizen', 'PaperlessBilling', 'AvgCostPerMonth', 'IsNewCustomer']
cat_cols = ['Contract', 'PaymentMethod', 'InternetService', 'TechSupport', 'OnlineSecurity']

preprocessor = get_preprocessor(num_cols, cat_cols)
X_train_proc = preprocessor.fit_transform(X_train)
X_test_proc = preprocessor.transform(X_test)

# 4. Train & Tune
lr, dt, rf = train_baseline_models(X_train_proc, y_train)
grid = run_grid_search(X_train_proc, y_train)
best_model = grid.best_estimator_

# 5. Evaluate
probs = best_model.predict_proba(X_test_proc)[:, 1]
preds = best_model.predict(X_test_proc)
auc = roc_auc_score(y_test, probs)

# 6. Save Results
save_model_visuals(y_test, probs, preds, auc)
report = f"Model: Random Forest Tuned\nAUC: {auc:.4f}\nBest Params: {grid.best_params_}"
write_report(report)

print("Proiectul a fost modularizat și executat cu succes!")
